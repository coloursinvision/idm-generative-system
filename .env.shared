# IDM Generative System — shared non-secret configuration.
#
# This file is JAWNE — committed to the repo. It carries infrastructure
# pointers (URLs, bucket names, hosts) that are not secrets and must be
# visible across the codebase, CI configs, and infrastructure-as-code.
#
# Secret values (API keys, tokens) live in secrets/app.enc.yaml,
# encrypted via SOPS+age.
#
# Loaded together with decrypted secrets at process start (see
# scripts/run-with-env.sh and SOPS_AGE_RUNBOOK.md §9).

# Qdrant Cloud — vector database
# Note: this URL points at our specific cluster but is technically
# a public DNS endpoint; treating it like MLFLOW_TRACKING_URI below.
QDRANT_URL=https://2dac7b8c-57ed-4175-8160-5de346ae7752.europe-west3-0.gcp.cloud.qdrant.io

# DigitalOcean Spaces — MLflow artifact store + DVC remote
DO_SPACES_BUCKET=idm-generative-system
DO_SPACES_ENDPOINT_URL=https://ams3.digitaloceanspaces.com

# MLflow — experiment tracking + model registry
MLFLOW_TRACKING_URI=https://mlflow.idm.coloursinvision.ai
MLFLOW_S3_ENDPOINT_URL=https://ams3.digitaloceanspaces.com

# Langfuse — LLM observability
LANGFUSE_HOST=https://cloud.langfuse.com
