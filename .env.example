# =============================================================================
# IDM Generative System — Environment Variables
# Copy to .env and fill in actual values. Never commit .env to version control.
# =============================================================================

# OpenAI — required for RAG pipeline (Advisor + Composer modes)
OPENAI_API_KEY=sk-your-key-here

# Qdrant Cloud — required for vector search
QDRANT_URL=https://your-cluster.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key

# Uvicorn — optional, override defaults
# UVICORN_PORT=8000
# UVICORN_WORKERS=2
# UVICORN_LOG_LEVEL=info
