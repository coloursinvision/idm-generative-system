# IDM Generative System — Environment Variables
# Copy to .env and fill in actual values.
# This file is safe to commit — it contains no secrets.

# OpenAI (required)
# Used by: knowledge/rag.py (GPT-4o completions + text-embedding-3-large)
OPENAI_API_KEY=sk-your-key-here

# Qdrant Cloud (required)
# Used by: knowledge/qdrant_client.py (vector search)
QDRANT_URL=https://your-cluster.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key

# Optional overrides
# UVICORN_PORT=8000
# UVICORN_WORKERS=2

# DigitalOcean Spaces (V2 — MLflow artifacts + DVC remote)
# Used by: MLflow artifact store, DVC push/pull
DO_SPACES_KEY=your-spaces-access-key
DO_SPACES_SECRET=your-spaces-secret-key
DO_SPACES_BUCKET=idm-generative-system
DO_SPACES_ENDPOINT_URL=https://ams3.digitaloceanspaces.com

# MLflow (V2 — experiment tracking)
# Used by: training scripts, model registry, CI smoke tests
MLFLOW_TRACKING_URI=https://mlflow.idm.coloursinvision.ai
MLFLOW_S3_ENDPOINT_URL=https://ams3.digitaloceanspaces.com
